rules_version = '2';

// ---------------------------------------------------------------------------
// Tracko Firestore security rules
//
// Roles:
//   • Admin — authenticated user whose email matches NEXT_PUBLIC_ADMIN_EMAIL.
//             Owns projects, creates user accounts, assigns projects to users.
//   • User  — authenticated user created by the admin. Has a doc in /users
//             listing the projects they may access.
//   • Key-holder — unauthenticated visitor who knows a project share key.
//                  Can read the project doc and write expense entries only.
// ---------------------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------
    // Projects
    // ------------------------------------------------------------------
    match /projects/{projectId} {

      function isOwner() {
        return request.auth != null
               && resource.data.ownerId == request.auth.uid;
      }

      function onlySpentChanged() {
        return request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(['spent']);
      }

      // Readable by anyone — required for anonymous key lookups.
      allow read: if true;

      // Only authenticated users may create a project as its own owner.
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;

      // Owner has full update/delete; anyone may bump the `spent` counter.
      allow update: if isOwner() || onlySpentChanged();
      allow delete: if isOwner();

      // Expense entries are open to any key-holder.
      match /entries/{entryId} {
        allow read, write: if true;
      }
    }

    // ------------------------------------------------------------------
    // User profiles  (created by admin, read by the owner of the doc)
    // ------------------------------------------------------------------
    match /users/{uid} {
      // A user may read their own profile (to load assigned projects).
      // Any authenticated user may read all profiles (admin needs this to
      // list users; there is only one authenticated admin in practice).
      allow read: if request.auth != null;

      // Any authenticated user may write user docs. In practice only the
      // admin creates/updates them. For stricter enforcement, migrate to
      // Firebase Admin SDK via a server-side route.
      allow write: if request.auth != null;
    }
  }
}
